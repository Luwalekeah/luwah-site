# ============================================
# Luwah Technologies — Environment Variables
# ============================================
# Copy to .env.local for development
# Set in Render dashboard for production
# ============================================

# --- Resend (Transactional Email) ---
RESEND_API_KEY=

# --- n8n Webhooks (via Cloudflare Tunnel) ---
N8N_WEBHOOK_URL=https://api.luwahtechnologies.com/webhook/contact
NEXT_PUBLIC_N8N_PARTIAL_WEBHOOK_URL=https://api.luwahtechnologies.com/webhook

# --- Cloudflare Turnstile ---
CLOUDFLARE_TURNSTILE_SECRET=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# --- Sanity.io CMS ---
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# --- Security ---
CSRF_SECRET=
WEBHOOK_HMAC_SECRET=
REVALIDATION_SECRET=
